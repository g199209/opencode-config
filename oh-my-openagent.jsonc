      "model": "newapi/kimi-k2.6",
      "variant": "high"
    },
    "quick": {
      "model": "newapi/deepseek-v4-flash",
      "variant": "high"
    },
    "unspecified-low": {
      "model": "newapi/deepseek-v4-flash",
      "variant": "high"
    },
    "unspecified-high": {
      "model": "newapi/kimi-k2.6",
      "variant": "high"
    },
